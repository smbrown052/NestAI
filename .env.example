# .env.example — NestAI environment variables
#
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control — it contains real secrets.
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (Docker Compose):
DATABASE_URL=******localhost:5432/nestai
POSTGRES_PASSWORD=change_me

# ── First admin account bootstrap ─────────────────────────────────────────────
# Used only once to create the first admin via:
#   python -m app.cli.seed_admin
# Remove or blank these after the account is created.
ADMIN_BOOTSTRAP_EMAIL=you@example.com
ADMIN_BOOTSTRAP_PASSWORD=

# ── FastAPI ───────────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_long_random_string
ENVIRONMENT=development
# Set to "true" to log all SQL queries (noisy, useful for debugging)
SQL_ECHO=false

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Walk Score ────────────────────────────────────────────────────────────────
WALKSCORE_API_KEY=

# ── Email (feedback notifications) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FEEDBACK_EMAIL=feedback@example.com

# ── Beta access ───────────────────────────────────────────────────────────────
# Comma-separated list of valid beta invite codes.
# Used by the legacy Streamlit app (st.secrets BETA_CODES).
BETA_CODES=
