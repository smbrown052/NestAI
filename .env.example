# .env.example — NestAI environment variables
#
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control — it contains real secrets.
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (Docker Compose):
DATABASE_URL=******localhost:5432/nestai
POSTGRES_PASSWORD=change_me

# ── First admin account bootstrap ─────────────────────────────────────────────
# Used only once to create the first admin via:
#   python -m app.cli.seed_admin
# Remove or blank these after the account is created.
ADMIN_BOOTSTRAP_EMAIL=you@example.com
ADMIN_BOOTSTRAP_PASSWORD=

# ── FastAPI ───────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production:
#   python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace_with_a_long_random_string
ENVIRONMENT=development
# Set to "true" to log all SQL queries (noisy, useful for debugging)
SQL_ECHO=false

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# How long access tokens remain valid (in hours). Default: 168 (7 days).
ACCESS_TOKEN_EXPIRE_HOURS=168
# Public URL of this application (used in password-reset and invite emails).
APP_URL=http://localhost:8000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Walk Score ────────────────────────────────────────────────────────────────
WALKSCORE_API_KEY=

# ── Email (feedback notifications & invitations) ──────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FEEDBACK_EMAIL=feedback@example.com

# ── Beta access ───────────────────────────────────────────────────────────────
# Comma-separated list of valid beta invite codes.
# Used by the legacy Streamlit app (st.secrets BETA_CODES).
BETA_CODES=

# ── Streamlit connection to FastAPI ───────────────────────────────────────────
# Set this in .streamlit/secrets.toml (not .env) so the Streamlit app can
# connect to the FastAPI backend for authentication.
# Example: NESTAI_API_URL = "http://localhost:8000"
# NESTAI_API_URL=
